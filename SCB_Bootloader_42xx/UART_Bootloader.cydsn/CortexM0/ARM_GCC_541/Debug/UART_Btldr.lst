 174:UART_Btldr.c  **** * Function Name: CyBtldrCommRead
 175:UART_Btldr.c  **** ********************************************************************************
 176:UART_Btldr.c  **** *
 177:UART_Btldr.c  **** * Summary:
 178:UART_Btldr.c  **** *  Receives the command. 
 179:UART_Btldr.c  **** *
 180:UART_Btldr.c  **** * Parameters:  
 181:UART_Btldr.c  **** *  pData:    A pointer to the area to store the block of data received
 182:UART_Btldr.c  **** *             from the device.
 183:UART_Btldr.c  **** *  size:     Maximum size of the read buffer
 184:UART_Btldr.c  **** *  count:    Pointer to an unsigned short variable to write the number
 185:UART_Btldr.c  **** *             of bytes actually read.
 186:UART_Btldr.c  **** *  timeOut:  Number of units to wait before returning because of a timeOut.
 187:UART_Btldr.c  **** *            Timeout is measured in 10s of ms.
 188:UART_Btldr.c  **** *
 189:UART_Btldr.c  **** * Return: 
 190:UART_Btldr.c  **** *  cystatus: This function will return CYRET_SUCCESS if at least one byte is received
 191:UART_Btldr.c  **** *			 successfully within the timeout interval. If no data is received this 
 192:UART_Btldr.c  **** *			 function will return CYRET_EMPTY.
 193:UART_Btldr.c  **** *
 194:UART_Btldr.c  **** * Theory: 
 195:UART_Btldr.c  **** *  'receivedDataCount' is updated with number of bytes received in the UART RX 
 196:UART_Btldr.c  **** *  interrupt routine. This variable is used to check whether some data is received 
 197:UART_Btldr.c  **** *  within the timeout period specified in *.cydwr. If data is received before the timeout, 
 198:UART_Btldr.c  **** *  the control will remain in another loop waiting for more data until no data is 
 199:UART_Btldr.c  **** *  received for a BYTE2BYTE_TIME_OUT(2 ms) interval.
 200:UART_Btldr.c  **** *
 201:UART_Btldr.c  **** *  Note: Increase the BYTE2BYTE_TIME_OUT to 10 ms for baud rates less than 9600.  
 202:UART_Btldr.c  **** * 
 203:UART_Btldr.c  **** *  BYTE2BYTE_TIME_OUT is used for detecting timeout marking end of block data from host. 
 204:UART_Btldr.c  **** *  This has to be set to a value which is greater than the expected maximum delay 
 205:UART_Btldr.c  **** *  between two bytes during a block/packet transmission from the host. 
 206:UART_Btldr.c  **** *  You have to account for the delay in hardware converters while calculating this value,
 207:UART_Btldr.c  **** *  if you are using any USB-UART bridges.   
 208:UART_Btldr.c  **** *******************************************************************************/
 209:UART_Btldr.c  **** cystatus CyBtldrCommRead(uint8 * pData, uint16 Size, uint16 * Count, uint8 TimeOut)
 210:UART_Btldr.c  **** {
 164              		.loc 1 210 0
