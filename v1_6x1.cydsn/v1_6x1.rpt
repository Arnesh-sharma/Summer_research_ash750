    <CYPRESSTAG name="Macrocell listing" icon="FILE_RPT_EQUATION">

    ------------------------------------------------------------
    Macrocell listing
    ------------------------------------------------------------

    MacroCell: Name=\TSTimer:TimerUDB:status_tc\, Mode=(Combinatorial)
        Total # of inputs        : 2
        Total # of product terms : 1
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              \TSTimer:TimerUDB:control_7\ * \TSTimer:TimerUDB:per_zero\
        );
        Output = \TSTimer:TimerUDB:status_tc\ (fanout=1)

    MacroCell: Name=\CapSense:csd_sense\, Mode=(Combinatorial)
        Total # of inputs        : 2
        Total # of product terms : 1
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              \CapSense:Net_1274\ * \CapSense:Net_1106\
        );
        Output = \CapSense:csd_sense\ (fanout=1)

    MacroCell: Name=\CapSense:cap_lo_en\, Mode=(Combinatorial)
        Total # of inputs        : 3
        Total # of product terms : 2
            Clock Enable: True
        Main Equation            : 2 pterms
        (
              !\CapSense:Net_1274\
            + !\CapSense:Net_1106\ * !\CapSense:Net_1652\
        );
        Output = \CapSense:cap_lo_en\ (fanout=1)

    MacroCell: Name=\CapSense:cap_hi_en\, Mode=(Combinatorial)
        Total # of inputs        : 3
        Total # of product terms : 2
            Clock Enable: True
        Main Equation            : 2 pterms
        (
              !\CapSense:Net_1274\
            + \CapSense:Net_1106\ * \CapSense:Net_1652\
        );
        Output = \CapSense:cap_hi_en\ (fanout=1)

    MacroCell: Name=__ONE__, Mode=(Combinatorial)
        Total # of inputs        : 0
        Total # of product terms : 0
            Clock Enable: True
        Main Equation            : 0 pterms
        !(
            0
        );
        Output = __ONE__ (fanout=1)

    MacroCell: Name=Net_29, Mode=(D-Register)
        Total # of inputs        : 2
        Total # of product terms : 1
        List of special equations: 
            Clock  = (Net_23_digital) => Global
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              \TSTimer:TimerUDB:control_7\ * \TSTimer:TimerUDB:per_zero\
        );
        Output = Net_29 (fanout=1)

    MacroCell: Name=\CapSense:Net_1274\, Mode=(D-Register)
        Total # of inputs        : 4
        Total # of product terms : 2
        List of special equations: 
            Clock  = (ClockBlock_HFClk) => Global
            Clock Enable: True
        Main Equation            : 2 pterms
        (
              \CapSense:Net_1274\ * \CapSense:Net_1176\
            + \CapSense:Net_1106\ * \CapSense:Net_1176\ * 
              !\CapSense:Net_1652\
        );
        Output = \CapSense:Net_1274\ (fanout=5)

    MacroCell: Name=\CapSense:Net_1106\, Mode=(D-Register)
        Total # of inputs        : 1
        Total # of product terms : 1
        List of special equations: 
            Clock  = (ClockBlock_HFClk) => Global
            Clock Enable: True
        Main Equation            : 1 pterm
        (
              \CapSense:Net_1652\
        );
        Output = \CapSense:Net_1106\ (fanout=4)
    </CYPRESSTAG>
