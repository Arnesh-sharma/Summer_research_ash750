 570:Generated_Source\PSoC4/CapSense_SelfTest.c ****         CapSense_dsRam.selfTest.testResultMask |= CapSense_TST_GLOBAL_CRC;
 571:Generated_Source\PSoC4/CapSense_SelfTest.c ****     }
 572:Generated_Source\PSoC4/CapSense_SelfTest.c ****     return result;
