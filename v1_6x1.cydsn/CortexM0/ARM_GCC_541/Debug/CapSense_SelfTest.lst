 560:Generated_Source\PSoC4/CapSense_SelfTest.c ****     uint16 crcValue = CapSense_DsCalculateCrc16((uint8 *)&CapSense_dsRam +
 561:Generated_Source\PSoC4/CapSense_SelfTest.c ****                                     CapSense_GLOBAL_CRC_AREA_START,
 562:Generated_Source\PSoC4/CapSense_SelfTest.c ****                                     CapSense_GLOBAL_CRC_AREA_SIZE);
