 598:Generated_Source\PSoC4/CapSense_SelfTest.c **** * Function Name: CapSense_CheckWidgetCRC
 599:Generated_Source\PSoC4/CapSense_SelfTest.c **** ****************************************************************************//**
 600:Generated_Source\PSoC4/CapSense_SelfTest.c **** *
 601:Generated_Source\PSoC4/CapSense_SelfTest.c **** * \brief
ARM GAS  C:\Users\ash750\AppData\Local\Temp\cchIVX1d.s 			page 12


 602:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  Checks the stored CRC of the CapSense_RAM_WD_BASE_STRUCT data
 603:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  structure of the specified widget.
 604:Generated_Source\PSoC4/CapSense_SelfTest.c **** *
 605:Generated_Source\PSoC4/CapSense_SelfTest.c **** * \details
 606:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  This function validates the data integrity of the
 607:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  CapSense_RAM_WD_BASE_STRUCT data structure of the specified widget
 608:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  by calculating the CRC and comparing it with the stored CRC value
 609:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  (i.e. CapSense_<WidgetName>_CRC_VALUE).
 610:Generated_Source\PSoC4/CapSense_SelfTest.c **** *
 611:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  If the stored and calculated CRC values differ:
 612:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  1. The calculated CRC is stored to the CapSense_WDGT_CRC_CALC_VALUE register
 613:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  2. The widget ID is stored to the CapSense_WDGT_CRC_ID_VALUE register
 614:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  3. The CapSense_TST_WDGT_CRC bit is set in the
 615:Generated_Source\PSoC4/CapSense_SelfTest.c **** *     CapSense_TEST_RESULT_MASK_VALUE register.
 616:Generated_Source\PSoC4/CapSense_SelfTest.c **** *
 617:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  The function never clears the CapSense_TST_WDGT_CRC bit.
 618:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  If the CapSense_TST_WDGT_CRC bit is set, the CapSense_WDGT_CRC_CALC_VALUE
 619:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  and CapSense_WDGT_CRC_ID_VALUE registers are not updated.
 620:Generated_Source\PSoC4/CapSense_SelfTest.c **** *
 621:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  It is recommended to use the CapSense_SetParam() function to change
 622:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  a value of CapSense_RAM_WD_BASE_STRUCT data structure register/elements
 623:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  as the CRC is updated by CapSense_SetParam() function.
 624:Generated_Source\PSoC4/CapSense_SelfTest.c **** *
 625:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  This test can be initiated by CapSense_RunSelfTest() function with
 626:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  the CapSense_TST_WDGT_CRC mask as an input.
 627:Generated_Source\PSoC4/CapSense_SelfTest.c **** *
 628:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  The function updates the wdgtWorking register
 629:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  CapSense_WDGT_WORKING<Number>_VALUE by clearing the widget-corresponding bit.
 630:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  Those non-working widgets are skipped by the high-level API.
 631:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  Restoring a widget to its working state should be done by the application level.
 632:Generated_Source\PSoC4/CapSense_SelfTest.c **** *
 633:Generated_Source\PSoC4/CapSense_SelfTest.c **** * \param widgetId
 634:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  Specifies the ID number of the widget to be processed.
 635:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  A macro for the widget ID can be found in the CapSense Configuration
 636:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  header file defined as CapSense_<WidgetName>_WDGT_ID.
 637:Generated_Source\PSoC4/CapSense_SelfTest.c **** *
 638:Generated_Source\PSoC4/CapSense_SelfTest.c **** * \return
 639:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  Returns a status of the test execution:
 640:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  - CYRET_SUCCESS - The stored CRC matches the calculated CRC.
 641:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  - CapSense_TST_WDGT_CRC - The widget CRC is wrong.
 642:Generated_Source\PSoC4/CapSense_SelfTest.c **** *  - CapSense_TST_BAD_PARAM - The input parameter is invalid.
 643:Generated_Source\PSoC4/CapSense_SelfTest.c **** *
 644:Generated_Source\PSoC4/CapSense_SelfTest.c **** *******************************************************************************/
 645:Generated_Source\PSoC4/CapSense_SelfTest.c **** uint32 CapSense_CheckWidgetCRC(uint32 widgetId)
 646:Generated_Source\PSoC4/CapSense_SelfTest.c **** {
 647:Generated_Source\PSoC4/CapSense_SelfTest.c ****     uint32 result = CapSense_TST_WDGT_CRC;
 648:Generated_Source\PSoC4/CapSense_SelfTest.c ****     uint16 crcValue = 0u;
 649:Generated_Source\PSoC4/CapSense_SelfTest.c ****     CapSense_RAM_WD_BASE_STRUCT *ptrWdgt;
 650:Generated_Source\PSoC4/CapSense_SelfTest.c **** 
 651:Generated_Source\PSoC4/CapSense_SelfTest.c ****     if (CapSense_TOTAL_WIDGETS > widgetId)
 652:Generated_Source\PSoC4/CapSense_SelfTest.c ****     {
 653:Generated_Source\PSoC4/CapSense_SelfTest.c ****         /* Get pointer to RAM object data */
 654:Generated_Source\PSoC4/CapSense_SelfTest.c ****         ptrWdgt = (CapSense_RAM_WD_BASE_STRUCT *)CapSense_dsFlash.wdgtArray[widgetId].ptr2WdgtRam;
 655:Generated_Source\PSoC4/CapSense_SelfTest.c ****         crcValue = CapSense_DsCalculateCrc16((uint8 *)ptrWdgt +
 656:Generated_Source\PSoC4/CapSense_SelfTest.c ****                                     CapSense_WIDGET_CRC_AREA_START,
 657:Generated_Source\PSoC4/CapSense_SelfTest.c ****                                     CapSense_WIDGET_CRC_AREA_SIZE);
 658:Generated_Source\PSoC4/CapSense_SelfTest.c ****         if ((ptrWdgt->crc) != crcValue)
ARM GAS  C:\Users\ash750\AppData\Local\Temp\cchIVX1d.s 			page 13


 659:Generated_Source\PSoC4/CapSense_SelfTest.c ****         {
 660:Generated_Source\PSoC4/CapSense_SelfTest.c ****             /* Write to self-test data structure wdgtId of the first bad tested widget */
 661:Generated_Source\PSoC4/CapSense_SelfTest.c ****             if (0Lu == (CapSense_dsRam.selfTest.testResultMask &
 662:Generated_Source\PSoC4/CapSense_SelfTest.c ****                        CapSense_TST_WDGT_CRC))
 663:Generated_Source\PSoC4/CapSense_SelfTest.c ****             {
 664:Generated_Source\PSoC4/CapSense_SelfTest.c ****                 CapSense_dsRam.selfTest.wdgtCrcCalc = crcValue;
 665:Generated_Source\PSoC4/CapSense_SelfTest.c ****                 CapSense_dsRam.selfTest.wdgtCrcId = (uint8)widgetId;
 666:Generated_Source\PSoC4/CapSense_SelfTest.c ****                 CapSense_dsRam.selfTest.testResultMask |= CapSense_TST_WDGT_CRC;
 667:Generated_Source\PSoC4/CapSense_SelfTest.c ****             }
 668:Generated_Source\PSoC4/CapSense_SelfTest.c ****             else
 669:Generated_Source\PSoC4/CapSense_SelfTest.c ****             {
 670:Generated_Source\PSoC4/CapSense_SelfTest.c ****             }
